OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
# If the frontend uses the default Next.js proxy (/api), browser CORS is not needed.
# Only add frontend origins here when the browser calls the backend directly.
CORS_ALLOW_ORIGINS=http://localhost:3000
PROMPT_PROFILE=default
# PROMPT_PROFILE_DIR=/absolute/path/to/your/prompt-profile
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# Optional: pre-configure Jira credentials at the host level.
# When set, all users share these credentials and do not need to enter them in the UI.
# Users can still override with their own credentials in Settings.
# JIRA_DOMAIN=yourcompany.atlassian.net
# JIRA_EMAIL=admin@yourcompany.com
# JIRA_TOKEN=your-jira-api-token

# Optional: pre-configure GitHub token at the host level.
# GITHUB_TOKEN=ghp_your-token
